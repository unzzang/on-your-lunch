{
  "expo": {
    "name": "온유어런치",
    "slug": "on-your-lunch",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "onyourlunch",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D4501F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kr.onyourlunch.app",
      "associatedDomains": ["applinks:api.onyourlunch.kr"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D4501F"
      },
      "package": "kr.onyourlunch.app",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.onyourlunch.kr",
              "pathPrefix": "/share"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "EAS_PROJECT_ID_HERE"
      }
    },
    "owner": "onyourlunch",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/EAS_PROJECT_ID_HERE"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D4501F"
        }
      ]
    ]
  }
}
