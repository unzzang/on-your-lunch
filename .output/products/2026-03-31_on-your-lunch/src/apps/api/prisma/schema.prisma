// 온유어런치 — Prisma Schema (ERD 14개 테이블 기반)
// PostGIS geom 컬럼은 Prisma에서 직접 지원하지 않으므로 수동 마이그레이션으로 추가

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// 2.1. USER (사용자)
// ─────────────────────────────────────────
model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String    @unique @db.VarChar(255)
  nickname               String    @db.VarChar(10)
  profileImageUrl        String?   @map("profile_image_url") @db.Text
  googleId               String    @unique @map("google_id") @db.VarChar(255)
  refreshToken           String?   @map("refresh_token") @db.Text
  notificationEnabled    Boolean   @default(true) @map("notification_enabled")
  notificationTime       String    @default("11:30") @map("notification_time") @db.VarChar(5)
  marketingAgreed        Boolean   @default(false) @map("marketing_agreed")
  termsAgreedAt          DateTime  @map("terms_agreed_at") @db.Timestamptz()
  expoPushToken          String?   @map("expo_push_token") @db.Text
  preferredPriceRange    String    @default("BETWEEN_10K_20K") @map("preferred_price_range") @db.VarChar(20)
  isOnboardingCompleted  Boolean   @default(false) @map("is_onboarding_completed")
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // 관계
  location              UserLocation?
  preferredCategories   UserPreferredCategory[]
  excludedCategories    UserExcludedCategory[]
  allergies             UserAllergy[]
  eatingHistories       EatingHistory[]
  favorites             Favorite[]
  recommendationLogs    RecommendationLog[]
  eventLogs             EventLog[]

  @@index([deletedAt], map: "idx_user_deleted_at")
  @@map("user")
}

// ─────────────────────────────────────────
// 2.2. USER_LOCATION (사용자 회사 위치)
// ─────────────────────────────────────────
model UserLocation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  latitude     Decimal  @db.Decimal(9, 6)
  longitude    Decimal  @db.Decimal(9, 6)
  address      String   @db.VarChar(255)
  buildingName String?  @map("building_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_location")
}

// ─────────────────────────────────────────
// 2.3. USER_PREFERRED_CATEGORY (선호 카테고리 N:M)
// ─────────────────────────────────────────
model UserPreferredCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId], map: "idx_upc_user_category")
  @@map("user_preferred_category")
}

// ─────────────────────────────────────────
// 2.3. USER_EXCLUDED_CATEGORY (제외 카테고리 N:M)
// ─────────────────────────────────────────
model UserExcludedCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId], map: "idx_uec_user_category")
  @@map("user_excluded_category")
}

// ─────────────────────────────────────────
// 2.3. USER_ALLERGY (알레르기 N:M)
// ─────────────────────────────────────────
model UserAllergy {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  allergyTypeId String   @map("allergy_type_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergyType AllergyType @relation(fields: [allergyTypeId], references: [id])

  @@unique([userId, allergyTypeId], map: "idx_ua_user_allergy")
  @@map("user_allergy")
}

// ─────────────────────────────────────────
// 2.4. CATEGORY (카테고리 마스터)
// ─────────────────────────────────────────
model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(30)
  colorCode String   @map("color_code") @db.VarChar(7)
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  restaurants          Restaurant[]
  preferredByUsers     UserPreferredCategory[]
  excludedByUsers      UserExcludedCategory[]
  eatingHistories      EatingHistory[]         @relation("ManualCategory")
  kakaoCategoryMappings KakaoCategoryMapping[]

  @@map("category")
}

// ─────────────────────────────────────────
// 2.5. ALLERGY_TYPE (알레르기 마스터)
// ─────────────────────────────────────────
model AllergyType {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String @unique @db.VarChar(20)
  sortOrder Int    @map("sort_order")

  userAllergies UserAllergy[]

  @@map("allergy_type")
}

// ─────────────────────────────────────────
// 2.6. RESTAURANT (식당)
// ─────────────────────────────────────────
model Restaurant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kakaoPlaceId  String?  @unique @map("kakao_place_id") @db.VarChar(50)
  name          String   @db.VarChar(100)
  categoryId    String   @map("category_id") @db.Uuid
  address       String   @db.VarChar(255)
  latitude      Decimal  @db.Decimal(9, 6)
  longitude     Decimal  @db.Decimal(9, 6)
  phone         String?  @db.VarChar(20)
  description   String?  @db.VarChar(200)
  priceRange    String?  @map("price_range") @db.VarChar(20)
  businessHours String?  @map("business_hours") @db.VarChar(200)
  thumbnailUrl  String?  @map("thumbnail_url") @db.Text
  isUserCreated Boolean  @default(false) @map("is_user_created")
  isClosed      Boolean  @default(false) @map("is_closed")
  dataSource    String   @default("KAKAO") @map("data_source") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // geom 컬럼은 수동 마이그레이션으로 추가 (PostGIS GEOGRAPHY(POINT, 4326))

  category                Category   @relation(fields: [categoryId], references: [id])
  menus                   RestaurantMenu[]
  photos                  RestaurantPhoto[]
  eatingHistories         EatingHistory[]
  favorites               Favorite[]
  recommendationLogItems  RecommendationLogItem[]

  @@index([categoryId], map: "idx_restaurant_category")
  @@map("restaurant")
}

// ─────────────────────────────────────────
// 2.7. RESTAURANT_MENU (식당 메뉴)
// ─────────────────────────────────────────
model RestaurantMenu {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String   @db.VarChar(100)
  price        Int?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId], map: "idx_restaurant_menu_restaurant")
  @@map("restaurant_menu")
}

// ─────────────────────────────────────────
// 2.8. RESTAURANT_PHOTO (식당 사진)
// ─────────────────────────────────────────
model RestaurantPhoto {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  imageUrl     String   @map("image_url") @db.Text
  isThumbnail  Boolean  @default(false) @map("is_thumbnail")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId], map: "idx_restaurant_photo_restaurant")
  @@map("restaurant_photo")
}

// ─────────────────────────────────────────
// 2.9. EATING_HISTORY (먹은 이력)
// ─────────────────────────────────────────
model EatingHistory {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  restaurantId           String?   @map("restaurant_id") @db.Uuid
  manualRestaurantName   String?   @map("manual_restaurant_name") @db.VarChar(100)
  manualCategoryId       String?   @map("manual_category_id") @db.Uuid
  eatenDate              DateTime  @map("eaten_date") @db.Date
  rating                 Int       @db.SmallInt
  memo                   String?   @db.VarChar(300)
  isFromRecommendation   Boolean   @default(false) @map("is_from_recommendation")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant     Restaurant? @relation(fields: [restaurantId], references: [id])
  manualCategory Category?   @relation("ManualCategory", fields: [manualCategoryId], references: [id])

  @@unique([userId, restaurantId, eatenDate], map: "idx_eating_history_user_date")
  @@index([userId, eatenDate(sort: Desc)], map: "idx_eating_history_user_recent")
  @@map("eating_history")
}

// ─────────────────────────────────────────
// 2.10. FAVORITE (즐겨찾기)
// ─────────────────────────────────────────
model Favorite {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId], map: "idx_favorite_user_restaurant")
  @@index([userId, createdAt(sort: Desc)], map: "idx_favorite_user_created")
  @@map("favorite")
}

// ─────────────────────────────────────────
// 2.11. RECOMMENDATION_LOG (추천 기록)
// ─────────────────────────────────────────
model RecommendationLog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String?  @map("user_id") @db.Uuid
  recommendationDate  DateTime @map("recommendation_date") @db.Date
  refreshCount        Int      @default(0) @map("refresh_count") @db.SmallInt
  filterCategoryIds   String[] @map("filter_category_ids") @db.Uuid
  filterPriceRange    String?  @map("filter_price_range") @db.VarChar(20)
  filterWalkMinutes   Int?     @map("filter_walk_minutes") @db.SmallInt
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user  User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  items RecommendationLogItem[]

  @@index([userId, recommendationDate(sort: Desc)], map: "idx_recommendation_log_user_date")
  @@map("recommendation_log")
}

// ─────────────────────────────────────────
// 2.12. RECOMMENDATION_LOG_ITEM (추천 상세)
// ─────────────────────────────────────────
model RecommendationLogItem {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recommendationLogId String @map("recommendation_log_id") @db.Uuid
  restaurantId        String @map("restaurant_id") @db.Uuid
  displayOrder        Int    @map("display_order") @db.SmallInt

  recommendationLog RecommendationLog @relation(fields: [recommendationLogId], references: [id], onDelete: Cascade)
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])

  @@index([recommendationLogId], map: "idx_rli_log_id")
  @@index([restaurantId], map: "idx_rli_restaurant")
  @@map("recommendation_log_item")
}

// ─────────────────────────────────────────
// 2.13. KAKAO_CATEGORY_MAPPING (카카오 카테고리 매핑)
// ─────────────────────────────────────────
model KakaoCategoryMapping {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kakaoCategory  String   @unique @map("kakao_category") @db.VarChar(100)
  categoryId     String?  @map("category_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  category Category? @relation(fields: [categoryId], references: [id])

  @@map("kakao_category_mapping")
}

// ─────────────────────────────────────────
// 2.14. EVENT_LOG (추적 이벤트)
// ─────────────────────────────────────────
model EventLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventName String   @map("event_name") @db.VarChar(50)
  eventData Json     @default("{}") @map("event_data") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)], map: "idx_event_log_user_created")
  @@index([eventName, createdAt(sort: Desc)], map: "idx_event_log_name_created")
  @@map("event_log")
}
