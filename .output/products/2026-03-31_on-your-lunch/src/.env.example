# 데이터베이스
DATABASE_URL=postgresql://사용자명@localhost:5432/onyourlunch

# JWT 인증
JWT_SECRET=여기에-비밀키-입력
JWT_REFRESH_SECRET=여기에-리프레시-비밀키-입력

# Google OAuth
GOOGLE_CLIENT_ID=여기에-구글-클라이언트-ID
GOOGLE_CLIENT_SECRET=여기에-구글-시크릿

# 서버
PORT=3000
NODE_ENV=development

# 카카오 API
KAKAO_REST_API_KEY=여기에-카카오-REST-API-키

# Sentry (에러 모니터링, 선택)
SENTRY_DSN=

# Cloudflare R2 (파일 저장, 선택)
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=

# Expo 푸시 (선택)
EXPO_ACCESS_TOKEN=
