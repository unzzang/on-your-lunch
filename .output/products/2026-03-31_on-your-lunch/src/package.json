{
  "name": "on-your-lunch",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "api:dev": "turbo run dev --filter=@on-your-lunch/api",
    "api:build": "turbo run build --filter=@on-your-lunch/api",
    "api:test": "turbo run test --filter=@on-your-lunch/api",
    "api:lint": "turbo run lint --filter=@on-your-lunch/api",
    "mobile:start": "turbo run start --filter=@on-your-lunch/mobile",
    "mobile:ios": "pnpm --filter @on-your-lunch/mobile exec expo start --ios",
    "mobile:android": "pnpm --filter @on-your-lunch/mobile exec expo start --android",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @on-your-lunch/api exec prisma generate",
    "db:migrate": "pnpm --filter @on-your-lunch/api exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @on-your-lunch/api exec prisma migrate deploy",
    "db:studio": "pnpm --filter @on-your-lunch/api exec prisma studio",
    "db:seed": "pnpm --filter @on-your-lunch/api exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.9.3"
  },
  "pnpm": {
    "overrides": {}
  }
}
